        {
          "name": "Profit Ratio",
          "caption": "Profit Ratio",
          "datatype": "real",
          "role": "measure",
          "type": "quantitative",
          "formula": "SUM([Profit])/SUM([Sales])",
          "is_calculated": true,
          "hidden": false
        },
        {
          "name": "Sales per Customer",
          "caption": "Sales per Customer",
          "datatype": "real",
          "role": "measure",
          "type": "quantitative",
          "formula": "SUM([Sales])/COUNTD([Customer ID])",
          "is_calculated": true,
          "hidden": false
        },
        {
          "name": "Days to Ship",
          "caption": "Days to Ship",
          "datatype": "integer",
          "role": "measure",
          "type": "quantitative",
          "formula": "DATEDIFF('day',[Order Date],[Ship Date])",
          "is_calculated": true,
          "hidden": false
        },
        {
          "name": "Above Average Sales",
          "caption": "Above Average Sales",
          "datatype": "boolean",
          "role": "dimension",
          "type": "nominal",
          "formula": "SUM([Sales]) > {FIXED [Region] : AVG(SUM([Sales]))}",
          "is_calculated": true,
          "hidden": false
        },
        {
          "name": "Profit Band",
          "caption": "Profit Band",
          "datatype": "string",
          "role": "dimension",
          "type": "nominal",
          "formula": "IF [Profit] > 500 THEN \"High\" ELSEIF [Profit] > 0 THEN \"Medium\" ELSE \"Loss\" END",
          "is_calculated": true,
          "hidden": false
        },
        {
          "name": "YTD Sales",
          "caption": "YTD Sales",
          "datatype": "real",
          "role": "measure",
          "type": "quantitative",
          "formula": "RUNNING_SUM(SUM([Sales]))",
          "is_calculated": true,
          "hidden": false
        },
        {
          "name": "Customer Upper",
